---
// Client-side only conversion app
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Conversor de Divisas a Bolívares</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
        background-color: #f5f5f5;
        color: #333;
        line-height: 1.6;
        padding: 20px;
      }

      .container {
        max-width: 500px;
        margin: 0 auto;
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        overflow: hidden;
      }

      header {
        background: #2c3e50;
        color: white;
        padding: 20px;
        text-align: center;
      }

      header h1 {
        font-size: 1.8rem;
        margin-bottom: 5px;
      }

      header p {
        font-size: 0.9rem;
        opacity: 0.9;
      }

      .rates-section {
        padding: 20px;
        border-bottom: 1px solid #eee;
      }

      .rate-item {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #f0f0f0;
      }

      .rate-item:last-child {
        border-bottom: none;
      }

      .rate-label {
        font-weight: 600;
      }

      .rate-value {
        font-family: 'Courier New', monospace;
        background: #f8f9fa;
        padding: 2px 6px;
        border-radius: 4px;
      }

      .converter-section {
        padding: 20px;
      }

      .input-group {
        margin-bottom: 20px;
      }

      .input-group label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
      }

      .input-group input {
        width: 100%;
        padding: 12px;
        font-size: 1.2rem;
        border: 2px solid #ddd;
        border-radius: 6px;
        text-align: right;
        font-family: 'Courier New', monospace;
        transition: border-color 0.3s;
      }

      .input-group input:focus {
        outline: none;
        border-color: #3498db;
      }

      .virtual-keyboard {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
      }

      button.key {
        aspect-ratio: 1;
        background: #ecf0f1;
        border: none;
        border-radius: 8px;
        font-size: 1.4rem;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .key:hover {
        background: #d5d8dc;
        transform: scale(1.05);
      }

      .key:active {
        transform: scale(0.98);
      }

      .key.wide {
        grid-column: span 3;
      }

      .key.action {
        background: #3498db;
        color: white;
      }

      .key.action:hover {
        background: #2980b9;
      }

      .result-section {
        padding: 20px;
        text-align: center;
        background: #f8f9fa;
        border-top: 1px solid #eee;
      }

      .result-label {
        display: block;
        margin-bottom: 10px;
        font-weight: 600;
        color: #666;
      }

      .result-value {
        font-size: 2.2rem;
        font-weight: bold;
        color: #2c3e50;
        font-family: 'Courier New', monospace;
      }

      .loading, .error {
        text-align: center;
        padding: 20px;
        color: #666;
      }

      .error {
        color: #e74c3c;
      }

      @media (max-width: 480px) {
        body {
          padding: 10px;
        }

        .virtual-keyboard {
          gap: 8px;
        }

        .key {
          font-size: 1.2rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <h1>Conversor Dolar</h1>
        <p>Precios actualizados desde BCV</p>
      </header>

      <section class="result-section">
        <div class="result-label">Equivalente en Bolívares:</div>
        <div class="rate-item">
          <span class="rate-label">Dolar BCV:</span>
          <span class="rate-value" id="usd-bvc-result">0.00 VES</span>
        </div>
        <div class="rate-item">
          <span class="rate-label">Euro BCV:</span>
          <span class="rate-value" id="eur-bvc-result">0.00 VES</span>
        </div>
        <div class="rate-item">
          <span class="rate-label">USDT:</span>
          <span class="rate-value" id="usdt-bvc-result">0.00 VES</span>
        </div>
      </section>

      <section class="converter-section">
        <div class="input-group">
          <label for="amount">Ingrese cantidad en USD:</label>
          <input
            type="text"
            id="amount"
            inputmode="decimal"
            placeholder="0.00"
            autocomplete="off"
          />
        </div>

        <div class="virtual-keyboard" id="keyboard">
          <!-- Keyboard buttons will be injected by JS -->
        </div>
      </section>

            <section class="rates-section">
        <div class="rate-item">
          <span class="rate-label">Dolar (BCV):</span>
          <span class="rate-value" id="dollar-rate">Cargando...</span>
        </div>
        <div class="rate-item">
          <span class="rate-label">Euro (BCV):</span>
          <span class="rate-value" id="euro-rate">Cargando...</span>
        </div>
        <div class="rate-item">
          <span class="rate-label">USDT:</span>
          <span class="rate-value" id="usdt-rate">Cargando...</span>
        </div>
      </section>


    </div>

    <script>
      // API Configuration
      const API_KEY = '1c3ebae6aad76cec95f364158a5d7d96576b36d33372a722c45db92132341726';
      const API_HEADERS = {
        'x-dolarvzla-key': API_KEY
      };

      // DOM Elements
      const dollarRateEl = document.getElementById('dollar-rate');
      const euroRateEl = document.getElementById('euro-rate');
      const usdtRateEl = document.getElementById('usdt-rate');
      const amountInput = document.getElementById('amount');
      const usdResultEl = document.getElementById('usd-bvc-result');
      const eurResultEl = document.getElementById('eur-bvc-result');
      const usdtResultEl = document.getElementById('usdt-bvc-result');
      const keyboardEl = document.getElementById('keyboard');

      // State
      let dollarRate = 0;
      let euroRate = 0;
      let usdtRate = 0;

      // Initialize
      async function init() {
        try {
          await Promise.all([
            fetchDollarEuroRate(),
            fetchUsdtRate()
          ]);
          createVirtualKeyboard();
          setupInputHandling();
        } catch (error) {
          showError('Error al cargar las tasas de cambio' + error);
          console.error('Init error:', error);
        }
      }

      // Fetch dollar and euro rates from BCV endpoint
      async function fetchDollarEuroRate() {
        try {
          console.log('Fetching dollar/euro rates...');
          const response = await fetch(
            'https://api.dolarvzla.com/public/bcv/exchange-rate',
            { headers: API_HEADERS }
          );

          console.log('Response status:', response.status);
          if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
          }

          const data = await response.json();
          console.log('BCV response data:', data);
          
          // Handle BCV response structure
          if (data.current && data.current.usd) {
            dollarRate = parseFloat(data.current.usd) || 0;
          } else if (data.USD && data.USD.promedio) {
            dollarRate = parseFloat(data.USD.promedio) || 0;
          } else if (data.dolar && data.dolar.promedio) {
            dollarRate = parseFloat(data.dolar.promedio) || 0;
          } else if (typeof data === 'number') {
            dollarRate = data;
          } else {
            // Try to find a numeric value in the response
            const rateMatch = String(data).match(/[\d,]+\.?\d*/);
            dollarRate = rateMatch ? parseFloat(rateMatch[0].replace(',', '')) : 0;
          }

          if (data.current && data.current.eur) {
            euroRate = parseFloat(data.current.eur) || 0;
          } else if (data.EUR && data.EUR.promedio) {
            euroRate = parseFloat(data.EUR.promedio) || 0;
          } else if (data.euro && data.euro.promedio) {
            euroRate = parseFloat(data.euro.promedio) || 0;
          } else {
            euroRate = 0; // Default if not found
          }

          displayRates();
        } catch (error) {
          console.error('Error fetching dollar/euro rate:', error);
          dollarRateEl.textContent = 'Error';
          euroRateEl.textContent = 'Error';
          showError('Error cargando tasas BCV: ' + error.message);
        }
      }

      // Fetch USDT rate
      async function fetchUsdtRate() {
        try {
          console.log('Fetching USDT rates...');
          const response = await fetch(
            'https://api.dolarvzla.com/public/usdt/exchange-rate',
            { headers: API_HEADERS }
          );

          console.log('Response status:', response.status);
          if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
          }

          const data = await response.json();
          console.log('USDT response data:', data);
          
          // Handle USDT response structure
          if (data.current && data.current.average) {
            usdtRate = parseFloat(data.current.average) || 0;
          } else if (data.USDT && data.USDT.promedio) {
            usdtRate = parseFloat(data.USDT.promedio) || 0;
          } else if (data.usdt && data.usdt.promedio) {
            usdtRate = parseFloat(data.usdt.promedio) || 0;
          } else if (typeof data === 'number') {
            usdtRate = data;
          } else {
            // Try to find a numeric value in the response
            const rateMatch = String(data).match(/[\d,]+\.?\d*/);
            usdtRate = rateMatch ? parseFloat(rateMatch[0].replace(',', '')) : 0;
          }

          displayRates();
        } catch (error) {
          console.error('Error fetching USDT rate:', error);
          usdtRateEl.textContent = 'Error';
          showError('Error cargando tasas USDT: ' + error.message);
        }
      }

      // Number formatting
      const numberFormatter = new Intl.NumberFormat('es-VE', {
        style: 'currency',
        currency: 'VES',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      });

      // Display rates in UI
      function displayRates() {
        dollarRateEl.textContent = numberFormatter.format(dollarRate);
        euroRateEl.textContent = numberFormatter.format(euroRate);
        usdtRateEl.textContent = numberFormatter.format(usdtRate);
      }

      // Create virtual keyboard
      function createVirtualKeyboard() {
        const keys = [
          '1', '2', '3',
          '4', '5', '6',
          '7', '8', '9',
          '0', '.', '←',
          'C'
        ];

        keyboardEl.innerHTML = '';
        
        keys.forEach(key => {
          const button = document.createElement('button');
          button.className = 'key';
          
          if (key === '←') {
            button.textContent = '←';
            button.classList.add('action');
          } else if (key === 'C') {
            button.textContent = 'C';
            button.classList.add('action');
            button.classList.add('wide');
          } else {
            button.textContent = key;
          }
          
          button.addEventListener('click', () => handleKeyPress(key));
          keyboardEl.appendChild(button);
        });
      }

      // Handle keyboard button presses
      function handleKeyPress(key) {
        const currentValue = amountInput.value;
        
        if (key === 'C') {
          amountInput.value = '';
        } else if (key === '←') {
          amountInput.value = currentValue.slice(0, -1);
        } else if (key === '.') {
          // Prevent multiple decimal points
          if (!currentValue.includes('.')) {
            amountInput.value = currentValue + '.';
          }
        } else {
          // Prevent leading zero unless it's a decimal
          if (currentValue === '0' && key !== '.') {
            amountInput.value = key;
          } else {
            amountInput.value = currentValue + key;
          }
        }
        
        // Trigger input event to update conversion
        amountInput.dispatchEvent(new Event('input'));
      }

      // Setup input handling for conversion
      function setupInputHandling() {
        amountInput.addEventListener('input', () => {
          const value = amountInput.value.trim();
          
          if (value === '' || value === '.') {
            usdResultEl.textContent = numberFormatter.format(0);
            eurResultEl.textContent = numberFormatter.format(0);
            usdtResultEl.textContent = numberFormatter.format(0);
            return;
          }
          
          const amount = parseFloat(value);
          
          if (isNaN(amount)) {
            usdResultEl.textContent = numberFormatter.format(0);
            eurResultEl.textContent = numberFormatter.format(0);
            usdtResultEl.textContent = numberFormatter.format(0);
            return;
          }
          
          // Conversiones a bolívares
          const usdToBvc = amount * dollarRate;
          const eurToBvc = amount * euroRate;
          const usdtToBvc = amount * usdtRate;
          
          usdResultEl.textContent = numberFormatter.format(usdToBvc);
          eurResultEl.textContent = numberFormatter.format(eurToBvc);
          usdtResultEl.textContent = numberFormatter.format(usdtToBvc);
        });
      }

      // Show error message
      function showError(message) {
        // Replace rates section with error
        const ratesSection = document.querySelector('.rates-section');
        ratesSection.innerHTML = `<p class="error">${message}</p>`;
      }

      // Initialize when DOM is loaded
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    </script>
  </body>
</html>
